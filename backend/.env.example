# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="SOC SaaS"
APP_VERSION="2.0.0"
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ─── API ──────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins.
# PRODUCTION: set to your frontend URL, e.g. https://your-frontend.up.railway.app
# The default CORS_ALLOW_ORIGIN_REGEX already covers *.up.railway.app deployments.
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Database ─────────────────────────────────────────────────────────────────
# LOCAL DEV (running backend directly on host):
DATABASE_URL=postgresql://soc_user:changeme@localhost:5432/soc_saas
# DOCKER COMPOSE: docker-compose.yml overrides this with the Docker service name.
# PRODUCTION (Railway): set to your Supabase/Railway Postgres URL.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ─── Redis ────────────────────────────────────────────────────────────────────
# LOCAL DEV (running backend directly on host):
REDIS_URL=redis://localhost:6379/0
# DOCKER COMPOSE: docker-compose.yml overrides this with the Docker service name.
# PRODUCTION (Railway): set to your Railway Redis URL (rediss://...).
REDIS_MAX_CONNECTIONS=20
# Optional: separate Redis DB for event streams. Defaults to REDIS_URL with DB 1.
# REDIS_STREAM_URL=redis://localhost:6379/1

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED — Generate with: openssl rand -hex 64 (both must differ)
JWT_SECRET=changeme_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=changeme_generate_different_secret_with_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# RS256 asymmetric key support (optional — leave blank to use HS256):
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_ATTEMPTS=10
RATE_LIMIT_API_REQUESTS=300
RATE_LIMIT_INGEST_EVENTS=10000

# ─── Workers ──────────────────────────────────────────────────────────────────
WORKER_STREAM_BLOCK_MS=5000
WORKER_CLAIM_IDLE_MS=30000
WORKER_MAX_RETRY=3

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# Get free Groq key at: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-key-here
# Get free Gemini key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# ─── Threat Intelligence ───────────────────────────────────────────────────────
ABUSEIPDB_API_KEY=
ALIENVAULT_API_KEY=
VIRUSTOTAL_API_KEY=
# GeoIP — MaxMind GeoLite2 (recommended: no rate limit, offline)
# 1. Register free at https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# 2. Download GeoLite2-City.mmdb and set the absolute path below
# 3. Install the library:  pip install ".[geoip]"
# Leave empty to fall back to ip-api.com (45 req/min free tier)
MAXMIND_DB_PATH=

# ─── Email / SMTP (fallback provider) ─────────────────────────────────────────
# Used only when Brevo and Resend are both unconfigured.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ─── Brevo (primary email provider) ───────────────────────────────────────────
# Recommended: no domain verification needed for non-owner recipients.
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_FROM_EMAIL=

# ─── Resend (secondary email provider) ────────────────────────────────────────
# Requires a verified domain for sending to non-owner addresses.
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── Observability ────────────────────────────────────────────────────────────
# Bearer token Prometheus uses to scrape /metrics. Leave empty to disable auth
# (metrics remain open in development; blocked entirely in production if empty).
# Generate with: openssl rand -hex 32
METRICS_SECRET_TOKEN=

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Set to your exact frontend URL in production.
# Used to build the CORS origin regex and email callback links.
FRONTEND_URL=http://localhost:5173
